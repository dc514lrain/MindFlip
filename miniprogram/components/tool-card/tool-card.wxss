/* 工具卡片通用组件样式 */

.tool-card {
  display: flex;
  align-items: center;
  gap: var(--spacing-md, 16rpx);
  background: var(--color-bg-card, #fff);
  border-radius: var(--radius-lg, 16rpx);
  padding: var(--spacing-lg, 24rpx);
  box-shadow: var(--shadow-card, 0 2rpx 12rpx rgba(0,0,0,0.06));
  cursor: pointer;
}

.card-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-md, 12rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: var(--color-bg, #FAFAF8);
}

.tool-card.coin .card-icon-wrap { background: #FFF3D4; }
.tool-card.dice .card-icon-wrap { background: #E3F2FD; }
.tool-card.roulette .card-icon-wrap { background: #F3E5F5; }
.tool-card.pros_cons .card-icon-wrap { background: #E8F5E9; }

.card-icon { width: 48rpx; height: 48rpx; }

.card-content { flex: 1; display: flex; flex-direction: column; gap: var(--spacing-xxs, 4rpx); }

.card-name {
  font-size: var(--font-size-base, 28rpx);
  font-weight: 700;
  color: var(--color-primary, #1A1A1A);
}

.card-desc {
  font-size: var(--font-size-xs, 22rpx);
  color: var(--color-secondary, #6B6B6B);
}

.card-arrow {
  font-size: var(--font-size-xl, 36rpx);
  color: var(--color-border, #E8E8E4);
  flex-shrink: 0;
}
