/* 自定义 Tab Bar 样式 */

.custom-tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 120rpx;
  z-index: var(--z-tab-bar, 100);
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-bar-bg {
  position: absolute;
  inset: 0;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-top: 1rpx solid var(--color-border, #E8E8E4);
}

.tab-item {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 24rpx;
  flex: 1;
  opacity: 0.6;
  transition: opacity var(--duration-fast, 150ms) ease;
}

.tab-item.active {
  opacity: 1;
}

.tab-icon-wrap {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-icon {
  font-size: 48rpx;
  line-height: 1;
}

.tab-label {
  font-size: 20rpx;
  color: var(--color-secondary, #6B6B6B);
  font-weight: 500;
}

.tab-item.active .tab-label {
  color: var(--color-primary, #1A1A1A);
  font-weight: 700;
}

/* 未读小红点 */
.unread-dot {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 16rpx;
  height: 16rpx;
  background: #F44336;
  border-radius: 50%;
  border: 2rpx solid #fff;
}

/* 中间凸起按钮 */
.center-btn-wrap {
  position: relative;
  z-index: 2;
  flex-shrink: 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  width: 120rpx;
}

.center-btn {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-accent, #E8B84B) 0%, #F0A500 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(232, 184, 75, 0.4);
  margin-bottom: 12rpx;
  transform: translateY(-24rpx);
}

.center-btn:active {
  transform: translateY(-20rpx);
  box-shadow: 0 4rpx 12rpx rgba(232, 184, 75, 0.3);
}

.center-btn-icon {
  font-size: 48rpx;
}
