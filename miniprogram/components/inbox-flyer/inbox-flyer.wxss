/* Inbox 飞入动效组件样式 */

.inbox-flyer-mask {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0);
  z-index: var(--z-toast, 300);
  pointer-events: none;
  transition: background var(--duration-normal, 250ms) ease;
}

.inbox-flyer-mask.visible {
  background: rgba(0, 0, 0, 0.2);
  pointer-events: all;
}

.flyer-toast {
  background: var(--color-primary, #1A1A1A);
  border-radius: var(--radius-round, 9999rpx);
  padding: var(--spacing-md, 16rpx) var(--spacing-xl, 32rpx);
  display: flex;
  align-items: center;
  gap: var(--spacing-sm, 12rpx);
  box-shadow: var(--shadow-float, 0 12rpx 48rpx rgba(0,0,0,0.16));
  transform: scale(0.8) translateY(20rpx);
  opacity: 0;
  transition: all var(--duration-slow, 400ms) cubic-bezier(0.34, 1.56, 0.64, 1);
}

.inbox-flyer-mask.visible .flyer-toast {
  transform: scale(1) translateY(0);
  opacity: 1;
}

.flyer-icon { font-size: 32rpx; }

.flyer-text {
  font-size: var(--font-size-base, 28rpx);
  font-weight: 600;
  color: #fff;
  white-space: nowrap;
}
