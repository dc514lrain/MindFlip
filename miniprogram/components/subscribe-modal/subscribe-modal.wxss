/* 订阅消息授权半屏弹窗样式 */

.subscribe-modal {
  position: fixed;
  inset: 0;
  z-index: var(--z-modal, 200);
  pointer-events: none;
}

.modal-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0);
  transition: background var(--duration-normal, 250ms) ease;
}

.subscribe-modal.visible .modal-mask {
  background: rgba(0, 0, 0, 0.4);
  pointer-events: all;
}

.modal-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--color-bg-card, #fff);
  border-radius: var(--radius-xl, 24rpx) var(--radius-xl, 24rpx) 0 0;
  padding: var(--spacing-sm, 12rpx) var(--spacing-lg, 24rpx) env(safe-area-inset-bottom);
  transform: translateY(100%);
  transition: transform var(--duration-slow, 400ms) cubic-bezier(0.32, 0.72, 0, 1);
}

.subscribe-modal.visible .modal-sheet {
  transform: translateY(0);
}

.modal-handle {
  width: 80rpx;
  height: 8rpx;
  background: var(--color-border, #E8E8E4);
  border-radius: 4rpx;
  margin: 0 auto var(--spacing-lg, 24rpx);
}

.modal-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-md, 16rpx);
  padding-bottom: var(--spacing-xl, 32rpx);
}

.modal-icon { font-size: 80rpx; }

.modal-title {
  font-size: var(--font-size-xl, 36rpx);
  font-weight: 800;
  color: var(--color-primary, #1A1A1A);
}

.modal-desc {
  font-size: var(--font-size-base, 28rpx);
  color: var(--color-secondary, #6B6B6B);
  text-align: center;
}

.benefit-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs, 8rpx);
  width: 100%;
  margin-top: var(--spacing-sm, 12rpx);
}

.benefit-item {
  font-size: var(--font-size-sm, 24rpx);
  color: var(--color-secondary, #6B6B6B);
  display: flex;
  align-items: center;
  gap: var(--spacing-sm, 12rpx);
}

.modal-actions {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm, 12rpx);
  width: 100%;
  margin-top: var(--spacing-lg, 24rpx);
}

.btn-authorize {
  width: 100%;
  height: 88rpx;
  background: var(--color-primary, #1A1A1A);
  color: #fff;
  border-radius: var(--radius-md, 12rpx);
  font-size: var(--font-size-lg, 32rpx);
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-later {
  width: 100%;
  height: 72rpx;
  background: transparent;
  color: var(--color-secondary, #6B6B6B);
  border-radius: var(--radius-md, 12rpx);
  font-size: var(--font-size-base, 28rpx);
}
