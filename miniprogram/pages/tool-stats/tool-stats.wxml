<!-- 单工具统计页（动态路由） -->
<view class="tool-stats-page">

  <!-- 工具标题 -->
  <view class="stats-header">
    <text class="tool-name">{{toolName}}</text>
    <text class="tool-desc">{{toolDescription}}</text>
  </view>

  <!-- 加载态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:else>
    <!-- 核心统计 -->
    <view class="core-stats">
      <view class="stat-card">
        <text class="stat-value">{{totalUses}}</text>
        <text class="stat-label">使用次数</text>
      </view>
      <view class="stat-card">
        <text class="stat-value">{{followRate}}%</text>
        <text class="stat-label">遵循率</text>
      </view>
    </view>

    <!-- 时间热力图 -->
    <view class="heatmap-section" wx:if="{{showHeatmap && heatmapData.length > 0}}">
      <view class="section-title">使用时间分布</view>
      <view class="heatmap-legend">
        <text class="legend-text">周一至周日 · 0-24时</text>
      </view>
      <view class="heatmap-grid">
        <view
          class="heatmap-row"
          wx:for="{{heatmapData}}"
          wx:for-item="row"
          wx:key="*this"
        >
          <view
            class="heatmap-cell"
            wx:for="{{row}}"
            wx:for-item="count"
            wx:key="*this"
            style="opacity: {{count > 0 ? (count >= maxHeat ? 1 : count / maxHeat * 0.7 + 0.2) : 0.08}}"
          />
        </view>
      </view>
    </view>

    <!-- 结果分布 -->
    <view class="distribution-section" wx:if="{{showDistribution && distribution.length > 0}}">
      <view class="section-title">结果分布</view>
      <view class="distribution-list">
        <view class="dist-item" wx:for="{{distribution}}" wx:key="key">
          <text class="dist-label">{{item.key}}</text>
          <view class="dist-bar-wrap">
            <view class="dist-bar" style="width: {{item.percent}}%;" />
          </view>
          <text class="dist-value">{{item.count}}次</text>
          <text class="dist-percent">{{item.percent}}%</text>
        </view>
      </view>
    </view>

    <!-- 遵循率环形图 -->
    <view class="followrate-section">
      <view class="section-title">遵循情况</view>
      <view class="followrate-chart">
        <view class="followrate-ring">
          <view class="ring-bg" />
          <view class="ring-fill" style="transform: rotate({{followRate * 3.6}}deg);" />
          <view class="ring-center">
            <text class="ring-value">{{followRate}}%</text>
            <text class="ring-label">遵循率</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 历史记录 -->
    <view class="history-section">
      <view class="section-title">历史记录</view>
      <view class="history-list" wx:if="{{history.length > 0}}">
        <view class="history-item" wx:for="{{history}}" wx:key="_id">
          <view class="history-left">
            <text class="history-result">{{item.semantic_result}}</text>
            <text class="history-memo" wx:if="{{item.user_memo}}">{{item.user_memo}}</text>
          </view>
          <view class="history-right">
            <text class="history-status status--{{item.follow_status}}">{{statusLabelMap[item.follow_status]}}</text>
            <text class="history-time">{{item.relativeTimeStr}}</text>
          </view>
        </view>
      </view>
      <view class="empty-history" wx:else>
        <text class="empty-icon">📋</text>
        <text class="empty-text">暂无历史记录</text>
      </view>
    </view>

  </block>

</view>
