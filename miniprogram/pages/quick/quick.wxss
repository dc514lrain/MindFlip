/* 快速选择页样式 */

.quick-page {
  min-height: 100vh;
  background: var(--color-bg);
  padding: var(--spacing-xxl) var(--spacing-lg);
  padding-bottom: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-xxl);
}

.quick-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-sm);
}

.hint-icon { font-size: 80rpx; }
.hint-text { font-size: var(--font-size-lg); color: var(--color-secondary); font-weight: 600; }

.quick-tools {
  display: flex;
  gap: var(--spacing-xl);
}

.quick-card {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-xl);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-md);
  box-shadow: var(--shadow-lg);
  cursor: pointer;
}

.quick-card.coin { background: linear-gradient(135deg, #FFF3D4 0%, #FFE0A0 100%); }
.quick-card.dice { background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%); }
.quick-card.roulette { background: linear-gradient(135deg, #F3E5F5 0%, #E1BEE7 100%); }

.quick-icon { font-size: 80rpx; }
.quick-name { font-size: var(--font-size-base); font-weight: 700; color: var(--color-primary); }
