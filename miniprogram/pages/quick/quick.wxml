<!-- 快速选择 Tab（中间凸起按钮对应的半屏面板） -->
<view class="quick-page">

  <!-- 顶部提示 -->
  <view class="quick-header">
    <text class="header-title">快速决策</text>
    <text class="header-sub">选择一个工具，马上开始</text>
  </view>

  <!-- 最近使用 -->
  <view class="section" wx:if="{{recentTools.length > 0}}">
    <view class="section-label">最近使用</view>
    <view class="quick-tools-grid">
      <view
        class="quick-tool-card"
        wx:for="{{recentTools}}"
        wx:key="id"
        bindtap="openTool"
        data-tool="{{item.id}}"
      >
        <text class="quick-tool-icon">{{item.id === 'coin' ? '🪙' : item.id === 'dice' ? '🎲' : item.id === 'roulette' ? '🎯' : '⚖️'}}</text>
        <text class="quick-tool-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 全部工具 -->
  <view class="section">
    <view class="section-label">全部工具</view>
    <view class="all-tools-list">
      <view
        class="all-tool-item"
        wx:for="{{allTools}}"
        wx:key="id"
        bindtap="openTool"
        data-tool="{{item.id}}"
      >
        <text class="tool-icon">{{item.id === 'coin' ? '🪙' : item.id === 'dice' ? '🎲' : item.id === 'roulette' ? '🎯' : '⚖️'}}</text>
        <view class="tool-info">
          <text class="tool-name">{{item.name}}</text>
          <text class="tool-desc">{{item.description}}</text>
        </view>
        <view class="tool-arrow">
          <text>›</text>
        </view>
      </view>
    </view>
  </view>

</view>
