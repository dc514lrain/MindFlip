/* 订阅消息授权引导页样式 */

.subscribe-guide-page {
  min-height: 100vh;
  background: var(--color-bg);
  padding: var(--spacing-xxl) var(--spacing-lg);
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xxl);
  box-sizing: border-box;
}

.guide-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-md);
  padding-top: var(--spacing-xxxl);
  text-align: center;
}

.guide-icon { font-size: 120rpx; }

.guide-title {
  font-size: var(--font-size-xxl);
  font-weight: 800;
  color: var(--color-primary);
}

.guide-desc {
  font-size: var(--font-size-base);
  color: var(--color-secondary);
  max-width: 500rpx;
}

.benefit-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-lg);
}

.benefit-item {
  display: flex;
  align-items: flex-start;
  gap: var(--spacing-md);
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  box-shadow: var(--shadow-card);
}

.benefit-icon { font-size: 48rpx; }

.benefit-text {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xxs);
  flex: 1;
}

.benefit-title {
  font-size: var(--font-size-base);
  font-weight: 700;
  color: var(--color-primary);
}

.benefit-desc {
  font-size: var(--font-size-sm);
  color: var(--color-secondary);
}

.guide-actions {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
  margin-top: auto;
}

.btn-authorize {
  width: 100%;
  height: 96rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-md);
  font-size: var(--font-size-lg);
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-skip {
  width: 100%;
  height: 72rpx;
  background: transparent;
  color: var(--color-secondary);
  border-radius: var(--radius-md);
  font-size: var(--font-size-base);
}
