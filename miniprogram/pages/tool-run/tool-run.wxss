/* 工具运行通用页样式（实际内容由各工具页面提供） */

.tool-run-page {
  min-height: 100vh;
  background: var(--color-bg);
  display: flex;
  flex-direction: column;
}

.tool-placeholder {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-md);
}

.placeholder-icon { font-size: 96rpx; }
.placeholder-text { font-size: var(--font-size-base); color: var(--color-secondary); }
