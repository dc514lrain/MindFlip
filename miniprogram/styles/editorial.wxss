/* 决策大师 (MindFlip) — 杂志风排版公用 class */
/* 供各页面组件复用，统一杂志风格排版 */

.editorial-title {
  font-size: var(--font-size-xxl);
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1.3;
  letter-spacing: -0.5rpx;
}

.editorial-subtitle {
  font-size: var(--font-size-lg);
  color: var(--color-secondary);
  line-height: 1.5;
}

.editorial-label {
  font-size: var(--font-size-xs);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  color: var(--color-accent);
  font-weight: 700;
}

.editorial-display {
  font-size: var(--font-size-display);
  font-weight: 800;
  color: var(--color-primary);
  letter-spacing: -1px;
  line-height: 1.1;
}
