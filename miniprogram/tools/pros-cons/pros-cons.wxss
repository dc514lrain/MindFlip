/* 优缺点对比工具样式 */

.pros-cons-page {
  min-height: 100vh;
  background: var(--color-bg);
  display: flex;
  flex-direction: column;
  padding: var(--spacing-lg);
  box-sizing: border-box;
  position: relative;
}

/* 主题输入 */
.topic-section {
  margin-bottom: var(--spacing-lg);
}

.topic-input {
  width: 100%;
  height: 88rpx;
  background: var(--color-bg-card);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 0 var(--spacing-md);
  font-size: var(--font-size-lg);
  font-weight: 600;
  box-sizing: border-box;
  color: var(--color-primary);
}

/* 优缺点输入区 */
.analysis-section {
  display: flex;
  gap: var(--spacing-md);
  flex: 1;
}

.column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.column-header {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  padding: var(--spacing-xs) 0;
  border-bottom: 2rpx solid var(--color-border);
  margin-bottom: var(--spacing-xs);
}

.pros-column .column-header { border-color: var(--color-followed); }
.cons-column .column-header { border-color: var(--color-not-followed); }

.column-icon { font-size: 32rpx; }
.column-title { font-size: var(--font-size-base); font-weight: 700; }

.item-list { display: flex; flex-direction: column; gap: var(--spacing-xs); }

.analysis-item { display: flex; flex-direction: column; }

.item-row {
  display: flex;
  align-items: center;
  gap: var(--spacing-xxs);
}

.item-input {
  flex: 1;
  height: 64rpx;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: 0 var(--spacing-xs);
  font-size: var(--font-size-sm);
  box-sizing: border-box;
  color: var(--color-primary);
}

.weight-selector {
  display: flex;
  gap: 2rpx;
  flex-shrink: 0;
}

.weight-btn {
  width: 40rpx;
  height: 40rpx;
  border: 1rpx solid var(--color-border);
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  color: var(--color-secondary);
  background: transparent;
}

.pros-column .weight-btn.active {
  background: rgba(60, 179, 113, 0.2);
  border-color: var(--color-followed);
  color: var(--color-followed);
}

.cons-column .weight-btn.active {
  background: rgba(229, 115, 115, 0.2);
  border-color: var(--color-not-followed);
  color: var(--color-not-followed);
}

.item-delete {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-error);
  font-size: 20rpx;
  flex-shrink: 0;
}

.add-item-btn {
  font-size: var(--font-size-sm);
  color: var(--color-secondary);
  padding: var(--spacing-xs) 0;
  background: transparent;
  text-align: left;
}

/* 分析按钮 */
.action-section {
  margin-top: var(--spacing-lg);
  display: flex;
  justify-content: center;
}

.analyze-btn {
  width: 400rpx;
  height: 88rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-round);
  font-size: var(--font-size-lg);
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-md);
}

/* 结果区 */
.result-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-md);
  padding: var(--spacing-xxl) var(--spacing-lg);
}

.result-badge {
  font-size: var(--font-size-lg);
  font-weight: 700;
  padding: var(--spacing-sm) var(--spacing-xl);
  border-radius: var(--radius-round);
}

.result-badge.pros { background: rgba(60,179,113,0.15); color: var(--color-followed); }
.result-badge.cons { background: rgba(229,115,115,0.15); color: var(--color-not-followed); }
.result-badge.neutral { background: rgba(107,107,107,0.1); color: var(--color-secondary); }

.result-semantic {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--color-primary);
  text-align: center;
}

.score-row {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
}

.score-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.score-value {
  font-size: var(--font-size-xxl);
  font-weight: 800;
}

.pros-column .score-value { color: var(--color-followed); }
.cons-column .score-value { color: var(--color-not-followed); }

.score-label { font-size: var(--font-size-xs); color: var(--color-secondary); }
.score-divider { font-size: var(--font-size-xl); font-weight: 700; color: var(--color-secondary); }

.result-time { font-size: var(--font-size-xs); color: var(--color-secondary); }

.memo-section { width: 100%; max-width: 600rpx; }

.memo-input {
  width: 100%; height: 80rpx;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 0 var(--spacing-md);
  font-size: var(--font-size-base);
  box-sizing: border-box;
  text-align: center;
}

.result-actions {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
  width: 100%;
  max-width: 600rpx;
  margin-top: var(--spacing-lg);
}

.btn-primary {
  width: 100%; height: 88rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-md);
  font-size: var(--font-size-lg);
  font-weight: 600;
  display: flex; align-items: center; justify-content: center;
}

.btn-secondary {
  width: 100%; height: 72rpx;
  background: transparent;
  color: var(--color-secondary);
  border-radius: var(--radius-md);
  font-size: var(--font-size-base);
}

.loading-overlay {
  position: absolute; inset: 0;
  background: rgba(250,250,248,0.9);
  display: flex; align-items: center; justify-content: center;
}
.loading-text { font-size: var(--font-size-lg); color: var(--color-secondary); }
