/* 遵循/未遵循操作浮层样式 */

.action-sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0);
  z-index: var(--z-modal, 200);
  pointer-events: none;
  transition: background var(--duration-normal, 250ms) ease;
}

.action-sheet-mask.visible {
  background: rgba(0, 0, 0, 0.4);
  pointer-events: all;
}

.action-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--color-bg-card, #fff);
  border-radius: var(--radius-xl, 24rpx) var(--radius-xl, 24rpx) 0 0;
  padding: var(--spacing-lg, 24rpx) var(--spacing-lg, 24rpx) env(safe-area-inset-bottom);
  transform: translateY(100%);
  transition: transform var(--duration-slow, 400ms) cubic-bezier(0.32, 0.72, 0, 1);
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm, 12rpx);
}

.action-sheet-mask.visible .action-sheet {
  transform: translateY(0);
}

.sheet-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-md, 16rpx) 0 var(--spacing-lg, 24rpx);
  border-bottom: 1rpx solid var(--color-border, #E8E8E4);
  margin-bottom: var(--spacing-sm, 12rpx);
}

.sheet-title {
  font-size: var(--font-size-lg, 32rpx);
  font-weight: 700;
  color: var(--color-primary, #1A1A1A);
}

.sheet-subtitle {
  font-size: var(--font-size-sm, 24rpx);
  color: var(--color-secondary, #6B6B6B);
  margin-top: var(--spacing-xs, 8rpx);
  max-width: 500rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sheet-item {
  display: flex;
  align-items: center;
  gap: var(--spacing-md, 16rpx);
  padding: var(--spacing-lg, 24rpx) var(--spacing-md, 16rpx);
  border-radius: var(--radius-md, 12rpx);
  cursor: pointer;
}

.sheet-item.primary {
  background: rgba(60, 179, 113, 0.08);
}

.sheet-item.danger {
  background: rgba(229, 115, 115, 0.08);
}

.sheet-item.cancel {
  justify-content: center;
  margin-top: var(--spacing-xs, 8rpx);
}

.item-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.item-icon-wrap.followed {
  background: rgba(60, 179, 113, 0.15);
}

.item-icon-wrap.not-followed {
  background: rgba(229, 115, 115, 0.15);
}

.item-icon {
  font-size: 36rpx;
}

.item-content {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xxs, 4rpx);
}

.item-title {
  font-size: var(--font-size-lg, 32rpx);
  font-weight: 600;
  color: var(--color-primary, #1A1A1A);
}

.item-desc {
  font-size: var(--font-size-xs, 22rpx);
  color: var(--color-secondary, #6B6B6B);
}

/* 未遵循原因列表 */
.break-reasons {
  display: none;
  flex-direction: column;
  gap: var(--spacing-sm, 12rpx);
  padding: var(--spacing-md, 16rpx) 0;
}

.break-reasons.expanded {
  display: flex;
}

.reason-title {
  font-size: var(--font-size-sm, 24rpx);
  color: var(--color-secondary, #6B6B6B);
  font-weight: 600;
}

.reason-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-xs, 8rpx);
}

.reason-item {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs, 8rpx);
  padding: var(--spacing-xs, 8rpx) var(--spacing-sm, 12rpx);
  border: 2rpx solid var(--color-border, #E8E8E4);
  border-radius: var(--radius-round, 9999rpx);
  font-size: var(--font-size-sm, 24rpx);
  transition: all var(--duration-fast, 150ms) ease;
}

.reason-item.selected {
  border-color: var(--color-not-followed, #E57373);
  background: rgba(229, 115, 115, 0.08);
}

.reason-icon {
  font-size: 24rpx;
}

.reason-label {
  color: var(--color-primary, #1A1A1A);
}

.confirm-btn {
  width: 100%;
  height: 88rpx;
  background: var(--color-not-followed, #E57373);
  color: #fff;
  border-radius: var(--radius-md, 12rpx);
  font-size: var(--font-size-lg, 32rpx);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: var(--spacing-sm, 12rpx);
}

.confirm-btn[disabled] {
  opacity: 0.5;
}

.cancel-text {
  font-size: var(--font-size-lg, 32rpx);
  color: var(--color-secondary, #6B6B6B);
}
