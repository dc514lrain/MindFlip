/* 大转盘工具样式 */

.roulette-page {
  min-height: 100vh;
  background: var(--color-bg);
  display: flex;
  flex-direction: column;
  padding: var(--spacing-xl) var(--spacing-lg);
  box-sizing: border-box;
  position: relative;
}

.options-section {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-lg);
}

.section-title {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--color-primary);
}

.option-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.option-item {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.option-input {
  flex: 1;
  height: 80rpx;
  background: var(--color-bg-card);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 0 var(--spacing-md);
  font-size: var(--font-size-base);
  color: var(--color-primary);
}

.option-delete {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(244, 67, 54, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-error);
  font-size: 24rpx;
  flex-shrink: 0;
}

.add-option-row {
  display: flex;
  justify-content: center;
}

.add-option-btn {
  padding: var(--spacing-sm) var(--spacing-xl);
  border: 2rpx dashed var(--color-accent);
  border-radius: var(--radius-md);
  background: transparent;
  color: var(--color-accent);
  font-size: var(--font-size-base);
}

.spin-section {
  margin-top: var(--spacing-lg);
  display: flex;
  justify-content: center;
}

.spin-btn {
  width: 300rpx;
  height: 96rpx;
  background: linear-gradient(135deg, var(--color-accent) 0%, #F0A500 100%);
  color: #fff;
  border-radius: var(--radius-round);
  font-size: var(--font-size-xl);
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-lg);
}

.spin-btn.disabled {
  background: var(--color-border);
  box-shadow: none;
}

.result-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-md);
  padding: var(--spacing-xxl) var(--spacing-lg);
}

.result-badge {
  font-size: var(--font-size-sm);
  color: var(--color-secondary);
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.result-value {
  font-size: var(--font-size-display);
  font-weight: 800;
  color: var(--color-primary);
  text-align: center;
}

.result-time {
  font-size: var(--font-size-xs);
  color: var(--color-secondary);
}

.memo-section { width: 100%; max-width: 600rpx; }

.memo-input {
  width: 100%; height: 80rpx;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 0 var(--spacing-md);
  font-size: var(--font-size-base);
  box-sizing: border-box;
  text-align: center;
}

.result-actions {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
  width: 100%;
  max-width: 600rpx;
  margin-top: var(--spacing-lg);
}

.btn-primary {
  width: 100%; height: 88rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-md);
  font-size: var(--font-size-lg);
  font-weight: 600;
  display: flex; align-items: center; justify-content: center;
}

.btn-secondary {
  width: 100%; height: 72rpx;
  background: transparent;
  color: var(--color-secondary);
  border-radius: var(--radius-md);
  font-size: var(--font-size-base);
}

.loading-overlay {
  position: absolute; inset: 0;
  background: rgba(250,250,248,0.9);
  display: flex; align-items: center; justify-content: center;
}
.loading-text { font-size: var(--font-size-lg); color: var(--color-secondary); }
