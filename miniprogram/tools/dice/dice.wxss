/* 骰子工具样式 */

.dice-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #FAFAF8 0%, #E8F4FD 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xxl) var(--spacing-lg);
  box-sizing: border-box;
  position: relative;
}

.dice-canvas {
  width: 500rpx;
  height: 500rpx;
  max-width: 70vw;
  max-height: 70vw;
  margin-bottom: var(--spacing-xl);
  border-radius: var(--radius-xl);
}

/* 骰子数量选择 */
.dice-count-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-lg);
  width: 100%;
}

.count-label {
  font-size: var(--font-size-base);
  color: var(--color-secondary);
  font-weight: 600;
}

.count-selector {
  display: flex;
  gap: var(--spacing-sm);
  flex-wrap: wrap;
  justify-content: center;
}

.count-btn {
  width: 80rpx;
  height: 80rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.8);
  transition: all var(--duration-fast) ease;
}

.count-btn.active {
  border-color: var(--color-info);
  background: rgba(33, 150, 243, 0.1);
}

.count-text {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--color-primary);
}

.tap-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-xs);
  margin-top: var(--spacing-lg);
}

.tap-hint-icon { font-size: 48rpx; animation: bounce 1.5s ease-in-out infinite; }
.tap-hint-text { font-size: var(--font-size-base); color: var(--color-secondary); }

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

/* 结果区 */
.result-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-md);
  width: 100%;
}

.result-dice-row {
  display: flex;
  gap: var(--spacing-md);
  flex-wrap: wrap;
  justify-content: center;
}

.result-face {
  font-size: 80rpx;
  font-weight: 800;
  padding: var(--spacing-sm) var(--spacing-lg);
  background: rgba(255,255,255,0.9);
  border-radius: var(--radius-md);
  border: 2rpx solid var(--color-border);
}

.result-face.highlight {
  color: var(--color-info);
  border-color: var(--color-info);
}

.result-total {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--color-primary);
}

.result-time {
  font-size: var(--font-size-xs);
  color: var(--color-secondary);
}

.memo-section { width: 100%; max-width: 600rpx; margin-top: var(--spacing-md); }

.memo-input {
  width: 100%;
  height: 80rpx;
  background: rgba(255,255,255,0.8);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 0 var(--spacing-md);
  font-size: var(--font-size-base);
  box-sizing: border-box;
  text-align: center;
}

.result-actions {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
  width: 100%;
  max-width: 600rpx;
  margin-top: var(--spacing-lg);
}

.btn-primary {
  width: 100%; height: 88rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-md);
  font-size: var(--font-size-lg);
  font-weight: 600;
  display: flex; align-items: center; justify-content: center;
}

.btn-secondary {
  width: 100%; height: 72rpx;
  background: transparent;
  color: var(--color-secondary);
  border-radius: var(--radius-md);
  font-size: var(--font-size-base);
}

.loading-overlay {
  position: absolute; inset: 0;
  background: rgba(250,250,248,0.9);
  display: flex; align-items: center; justify-content: center;
}
.loading-text { font-size: var(--font-size-lg); color: var(--color-secondary); }
