{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "types": ["miniprogram-api-typings"],
    "strict": false,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": false,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "declaration": false,
    "noEmitOnError": false,
    "baseUrl": ".",
    "paths": {
      "@core/*": ["miniprogram/core/*"],
      "@tools/*": ["miniprogram/tools/*"],
      "@pages/*": ["miniprogram/pages/*"],
      "@components/*": ["miniprogram/components/*"],
      "@styles/*": ["miniprogram/styles/*"],
      "@assets/*": ["miniprogram/assets/*"]
    }
  },
  "include": ["miniprogram/**/*.ts"],
  "exclude": ["node_modules", "dist", "cloudfunctions"]
}