# Dependency directory (if using npm)
node_modules/

# Local development tool configuration
.idea/
.vscode/
*.swp
*.swo

# operating system generated files
.DS_Store
Thumbs.db

# Applet build or temporary file
miniprogram_npm/        # npm built package (generated by package.json)
dist/                   # If you put the compilation output in this directory
.eslintcache
*.log

# 排除 TypeScript 编译产物（保留原生 JS）
miniprogram/**/*.js
!miniprogram/utils/util.js
!miniprogram/miniprogram_npm/